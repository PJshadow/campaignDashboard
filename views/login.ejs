<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Dashboard IA — Login">
    <title>Dashboard IA — Login</title>
    <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet">
</head>

<body>
    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-card-header">
                <img src="/assets/img/logo.png" alt="Logo">
                <h2>Bem vindo</h2>
                <p>Faça login para acessar o painel</p>
            </div>

            <form action="/login" method="POST">
                <div class="login-card-body">
                    <div class="form-group">
                        <label for="inputEmail">Email</label>
                        <input name="email" id="inputEmail" type="email" placeholder="seu@email.com" required>
                    </div>
                    <div class="form-group">
                        <label for="inputPassword">Senha</label>
                        <input name="password" id="inputPassword" type="password" placeholder="••••••••" required>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" id="inputRemember" name="remember" value="1">
                        <label for="inputRemember">Permanecer logado</label>
                    </div>
                </div>

                <div class="login-card-footer">
                    <span></span>
                    <button type="submit" class="btn btn-primary">Entrar</button>
                </div>
            </form>
        </div>
    </div>
</body>

</html>